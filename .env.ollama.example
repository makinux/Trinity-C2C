# .env.ollama — run the gateway against the bundled local Ollama service (no GPU required).
#
# Usage:
#   cp .env.ollama.example .env.ollama
#   docker compose --env-file .env.ollama up -d --build --wait gateway ollama ollama-pull   # first run builds + pulls
#   # then open http://localhost:8080/  and UNCHECK "Mock mode (offline)"
#   docker compose down                                                                     # stop (down -v drops models)
#
# Naming the services (instead of `--profile ollama up`) avoids also starting the heavy `app`
# container, and a dedicated --env-file keeps your default `.env` / mock setup untouched.

# Use real models instead of the offline mock backend
TRINITY_GATEWAY_MOCK=0

# All three roles talk to the bundled Ollama (OpenAI-compatible) over the compose network
THINKER_URL=http://ollama:11434/v1
WORKER_URL=http://ollama:11434/v1
VERIFIER_URL=http://ollama:11434/v1

# Per-role Ollama model tags. The `ollama-pull` service pulls exactly these, and the gateway
# uses them as each role's model_id (via the <ROLE>_MODEL_ID override in trinity/config.py).
# Small defaults run on CPU; bump to :7b (or larger) if you have the RAM/GPU. Distinct lineages
# per role preserve the intended error-decorrelation (Thinker / Worker / Verifier).
THINKER_MODEL_ID=qwen2.5:3b
WORKER_MODEL_ID=qwen2.5-coder:3b
VERIFIER_MODEL_ID=deepseek-r1:1.5b
