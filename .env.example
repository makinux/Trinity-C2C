# cp .env.example .env して調整。docker compose が自動で読み込む。
# HFのレート制限緩和/ゲートモデル用（任意）
HF_TOKEN=

# 実データセットローダ(evalplus)をイメージに含める場合 1
WITH_DATASETS=0

# GPUプロファイルで使うローカルLLM（自分の手元モデルIDに置き換え可）
THINKER_MODEL=THUDM/glm-4-9b-chat
WORKER_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct
VERIFIER_MODEL=deepseek-ai/DeepSeek-R1-Distill-Qwen-7B
