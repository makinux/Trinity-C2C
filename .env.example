# Copy .env.example to .env and adjust. docker compose loads it automatically.
# For HF rate-limit relief / gated models (optional)
HF_TOKEN=

# Set to 1 to bundle the real dataset loader (evalplus) into the image
WITH_DATASETS=0

# Local LLMs used by the GPU profile (replace with your own local model IDs)
THINKER_MODEL=THUDM/glm-4-9b-chat
WORKER_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct
VERIFIER_MODEL=deepseek-ai/DeepSeek-R1-Distill-Qwen-7B
